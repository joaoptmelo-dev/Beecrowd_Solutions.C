#include <stdio.h>
#include <cstdlib>
#include <cmath>

int main(){
	double EV1,EV2,AT,D,EVa,EVb,G,P,Tot;
	do
	{
		scanf("%lf %lf %lf %lf",&EV1,&EV2,&AT,&D);
		if (EV1 == 0 && EV2 == 0 && AT == 0 && D == 0)
		break;
		else{
			EVa=ceil(EV1/D);
			EVb=ceil(EV2/D);
			G=AT/6.0;     //Esse exercício engana.
			P=1-G;        //Parece fácil a primeira vista mas entra em matérias mais avançadas...
			if(AT==6){    //Tive q estudar o básico de teoria dos jogos pra conseguir fazer
			Tot=100.0;
			printf("%.1lf\n",Tot);}
			else if(AT==3){
			Tot=EVa/(EVa+EVb);
			printf("%.1lf\n",Tot*100);}
			else{
			Tot=(1-pow(P/G,EVa))/(1-pow(P/G,EVa+EVb));
			printf("%.1lf\n",Tot*100);}
	    }
	}while(1);
	
	return 0;
}
