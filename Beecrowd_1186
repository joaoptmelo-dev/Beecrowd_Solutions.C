#include <stdio.h>

int main() {
    int i,j;
    char O;
    float M[12][12],Res=0;
    
    scanf(" %c",&O);
    for(i=0;i<12;i++)
    {
    	for(j=0;j<12;j++)
    	scanf("%f",&M[i][j]);
	}
	for(i=0;i<12;i++)
	{
		for(j=0;j<12;j++)
		{
			if(i+j>12-1) //PODE COLOCAR SÓ 11. COLOQUEI 12-1 PRA SABER DE ONDE TIREI O VALOR (É O VALOR DA DIAGONAL SECUNDÁRIA)
			Res+=M[i][j];
		}
	}
	if(O=='M')
	Res=Res/66;
	printf("%.1f\n",Res);
	
    return 0;
}
