#include <stdio.h>

int main() {
    int i,j,qnt=0;
    char O;
    double M[12][12],Res=0; //Tome cuidado. Tomei errado no exercício duas vezes por ter botado a variável como Float.
    
    scanf(" %c",&O);
    for(i=0;i<12;i++)
    {
    	for(j=0;j<12;j++)
    	scanf("%lf",&M[i][j]);
	}
	for(i=0;i<12;i++)
	{
		for(j=i+1;j<12;j++)
		{
			if(i+j<12-1)
			{
			Res+=M[i][j];
			qnt++;
		    }
		}
	}
	if(O=='M')
	Res=Res/qnt;
	printf("%.1lf\n",Res);
	
    return 0;
}
