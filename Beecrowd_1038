#include <stdio.h>
#include <cstdlib>
#include <cmath>

int main(){
	float N,Q;
	
	scanf("%f",&N);
	scanf("%f",&Q);
	
	if(N==1)
	printf("Total: R$ %.2f\n",Q*4);
	else{
		if(N==2)
		printf("Total: R$ %.2f\n",Q*4.5);
		else{
			if(N==3)
			printf("Total: R$ %.2f\n",Q*5);
			else{
				if(N==4)
				printf("Total: R$ %.2f\n",Q*2);
				else{
					if(N==5)
					printf("Total: R$ %.2f\n",Q*1.5);
				}
			}
		}
	}

	return 0;
}
