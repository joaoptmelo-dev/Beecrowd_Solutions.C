#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main(){
	int M,N;
	char Soma[500]={0};
	do{
		scanf("%d %d",&M,&N);
		if(N==0&&M==0)
		break;
		sprintf(Soma,"%d",M+N);
		int i=0,Z=0;
		while(Soma[i]!='\0')
		{
			while(Soma[i+Z]=='0')
			Z++;
			Soma[i]=Soma[i+Z];
			i++;
		}
		printf("%s\n",Soma);
	}while(1);
	
	return 0;
}
