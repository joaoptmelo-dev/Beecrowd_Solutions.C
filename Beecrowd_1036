#include <stdio.h>
#include <cstdlib>
#include <cmath>

int main(){
	double A,B,C,R1,R2,raiz;
	
	scanf("%lf",&A);
	scanf("%lf",&B);
	scanf("%lf",&C);
	raiz=(B*B)-(4*A*C);
	if(A==0 || raiz<0)
	printf("Impossivel calcular\n");
	else{
	R1=(-B+sqrt(raiz))/(2*A);
	R2=(-B-sqrt(raiz))/(2*A);
	printf("R1 = %.5lf\nR2 = %.5lf\n",R1,R2);
}

	return 0;
}
