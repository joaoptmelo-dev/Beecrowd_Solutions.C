#include <stdio.h>
#include <cstdlib>
#include <cmath>

int main(){
	int Ni,Nf,n100=0,n50=0,n20=0,n10=0,n5=0,n2=0,n1=0;
	
	scanf("%d",&Nf);
	Ni=Nf;
	while(Nf>=100){
		Nf=Nf-100;
		n100++;
	}
	while(Nf>=50){
		Nf=Nf-50;
		n50++;
	}
	while(Nf>=20){
		Nf=Nf-20;
		n20++;
	}
	while(Nf>=10){
		Nf=Nf-10;
		n10++;
	}
	while(Nf>=5){
		Nf=Nf-5;
		n5++;
	}
	while(Nf>=2){
		Nf=Nf-2;
		n2++;
	}
	while(Nf>=1){
		Nf=Nf-1;
		n1++;
	}
	printf("%d\n%d nota(s) de R$ 100,00\n%d nota(s) de R$ 50,00\n%d nota(s) de R$ 20,00\n%d nota(s) de R$ 10,00\n%d nota(s) de R$ 5,00\n%d nota(s) de R$ 2,00\n%d nota(s) de R$ 1,00\n",Ni,n100,n50,n20,n10,n5,n2,n1);
	
	return 0;
}
