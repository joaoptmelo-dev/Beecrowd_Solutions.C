#include <stdio.h>
#include <string.h>

int main() {
	int N,i;
	char V[50000];
	
    scanf("%d",&N);
    for(i=0;i<N;i++)
    {
    	int nled=0,j=0;
    	scanf("%s",V);
    	while(V[j]!='\0')
    	{
    		switch (V[j]){
    			case'1':nled+=2; break;
    			case'2':
    			case'3':nled+=5; break;
    			case'4':nled+=4; break;
    			case'5':nled+=5; break;
    			case'6':nled+=6; break;
    			case'7':nled+=3; break;
    			case'8':nled+=7; break;
    			case'9':
    			case'0':nled+=6; break;
			}
			j++;
		}
		printf("%d leds\n",nled);
	}
   
    return 0;
}
