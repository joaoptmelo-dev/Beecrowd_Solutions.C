#include <stdio.h>

int main() {
    int C,i,j;
    char O;
    float M[12][12],Res=0;
    
    scanf("%d",&C);
    scanf(" %c",&O);
    for(i=0;i<12;i++)
    {
    	for(j=0;j<12;j++)
    	{
    		scanf("%f",&M[i][j]);
		}
	}
	for(i=0;i<12;i++)
	Res=Res+M[i][C];
    if(O='M')
    Res=Res/12;
    printf("%.1f\n",Res);

    return 0;
}
